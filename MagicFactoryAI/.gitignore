# OS
.DS_Store
Thumbs.db
desktop.ini

# Windows reserved MS-DOS device names (these are NOT real files —
# they are device handles that Git on Windows sometimes lists as
# phantom untracked entries when shell commands like `> nul` are
# mis-parsed. Add other reserved names (con, aux, prn, com*, lpt*)
# defensively so they cannot pollute the working tree either.)
nul
con
aux
prn
com1
com2
com3
com4
com5
com6
com7
com8
com9
lpt1
lpt2
lpt3
lpt4
lpt5
lpt6
lpt7
lpt8
lpt9

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Environment
.env
.env.*
*.zip