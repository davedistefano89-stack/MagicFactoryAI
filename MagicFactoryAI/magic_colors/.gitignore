# ── M2.4 test scratch — the ParentGate suite stages a Hive box here
# for the resolve-failure case. The directory is recreated by
# `flutter test test/unit/coloring/parent_gate_flow_test.dart` and
# need not be tracked.
.hive_parent_gate_test/

# ── M2.4 RC1 SCOPE — only the `web/` target ships ──────────────────
# RC1 ships the Flutter web target only. Mobile (Android / iOS) and
# desktop (Linux / macOS / Windows) scaffolds stay out of git until a
# later minor merges them in:
#   ▸ Mobile native code is the unmodified `flutter create` placeholder
#     (com.example.magic_colors namespace / applicationId as seen
#     in android/app/build.gradle) — not production-ready.
#   ▸ The Win32 dev box lacks the Visual Studio C++ workload, so
#     Windows desktop builds are blocked. Linux/macOS aren't RC1
#     release targets.
#   ▸ Reversibility: any of these can be re-promoted via
#     `git add -f <dir>/` once the matching platform merge lands, OR
#     by deleting the corresponding `*/` line from this file.
#
# `.metadata` is the Flutter project marker file Flutter creates on
# macOS/Linux during `flutter create` and on Windows-equivalents;
# it's machine-local by convention and shouldn't be tracked.

# Flutter-generated machine-local marker
.metadata

# Mobile scaffolding (deferred past RC1)
android/
ios/

# Desktop scaffolding (deferred past RC1)
linux/
macos/
windows/

# ── Diagnostic scratch (M2.4 transient paths) ─────────────────────
# Generated by ad-hoc investigative bash sessions (drives the parent
# dashboard gate analysis, the bisect runs that landed the @Tags
# skip, the diagnostic probe file in _probe/m2_4_phase2_probe). All
# reproducible from source — never tracked.
.hive_daily_reward_test/
analyze.txt
analyze2.txt
daily_reward_claim_test_numbered.txt
analysis_options.yaml.bak
